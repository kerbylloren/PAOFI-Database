{
  "name": "paofi-database-native",
  "version": "2.0.1",
  "private": true,
  "description": "Desktop database app for PAOFI program records.",
  "author": {
    "name": "Kerby Lloren"
  },
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron:dev": "electron .",
    "package:standalone": "powershell.exe -ExecutionPolicy Bypass -File scripts/build-standalone.ps1",
    "package:installer": "powershell.exe -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "test": "node --test test/*.test.js",
    "import:csv": "node scripts/import-masterlist-csv.js",
    "import:scholarship-roster": "node scripts/import-scholarship-roster.js",
    "import:scholarship-access": "node scripts/import-scholarship-access.js",
    "normalize:db": "node scripts/normalize-database-capitalization.js",
    "cloud:config": "node scripts/configure-cloud.js",
    "migrate:cloud": "node scripts/migrate-sqlite-to-turso.js"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@napi-rs/canvas": "^1.0.2",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "pdfjs-dist": "^6.1.200",
    "tesseract.js": "^7.0.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "org.paofi.database",
    "productName": "PAOFI Database",
    "copyright": "Copyright (c) 2026 Kerby Lloren",
    "asar": false,
    "publish": [
      {
        "provider": "github",
        "owner": "kerbylloren",
        "repo": "PAOFI-Database",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "server.js",
      "package.json",
      "public/**/*",
      "src/**/*"
    ],
    "extraResources": [
      {
        "from": "build/cloud-defaults.json",
        "to": "cloud-defaults.json"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "PAOFI-Database-Setup-${version}-x64.${ext}",
      "include": "build/installer.nsh",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PAOFI Database",
      "uninstallDisplayName": "PAOFI Database"
    },
    "portable": {
      "artifactName": "PAOFI-Database-Standalone-${version}-x64.${ext}"
    }
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
