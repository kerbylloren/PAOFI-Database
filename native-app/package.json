{
  "name": "lp-database-native",
  "version": "0.1.3",
  "private": true,
  "description": "Desktop database app for LP beneficiary records.",
  "author": {
    "name": "Kerby Lloren"
  },
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron:dev": "electron .",
    "package:standalone": "powershell.exe -ExecutionPolicy Bypass -File scripts/build-standalone.ps1",
    "package:installer": "powershell.exe -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "test": "node --test test/*.test.js",
    "import:csv": "node scripts/import-masterlist-csv.js",
    "normalize:db": "node scripts/normalize-database-capitalization.js",
    "cloud:config": "node scripts/configure-cloud.js",
    "migrate:cloud": "node scripts/migrate-sqlite-to-turso.js"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "org.paofi.lpdatabase",
    "productName": "PAOFI LP Database",
    "copyright": "Copyright (c) 2026 Kerby Lloren",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron-main.js",
      "server.js",
      "package.json",
      "public/**/*",
      "src/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "PAOFI-LP-Database-Setup-${version}-x64.${ext}",
      "include": "build/installer.nsh",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PAOFI LP Database",
      "uninstallDisplayName": "PAOFI LP Database"
    },
    "portable": {
      "artifactName": "PAOFI-LP-Database-Standalone-${version}-x64.${ext}"
    }
  }
}
